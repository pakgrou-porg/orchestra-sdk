# Orchestra Secrets — fill in base64-encoded values
# Encode: echo -n "your-value" | base64
# Apply: kubectl apply -f k8s/secrets.yaml -n orchestra
#
# IMPORTANT: Never commit secrets.yaml (only secrets.yaml.template)

apiVersion: v1
kind: Secret
metadata:
  name: orchestra-secrets
  namespace: orchestra
type: Opaque
data:
  OPENROUTER_API_KEY: <base64-encoded-key>
  ANTHROPIC_API_KEY: <base64-encoded-key>
  SUPABASE_URL: <base64-encoded-url>
  SUPABASE_ANON_KEY: <base64-encoded-key>
