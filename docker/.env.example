# Orchestra Framework — Environment Variables
# Copy to .env and fill in your values.

# LLM API keys (set the one matching your conductor_config.yaml llm.api_key_env)
OPENROUTER_API_KEY=sk-or-v1-...
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Supabase
SUPABASE_URL=https://your-project.supabase.co
# Trusted backend key (Conductor runtime + migrations). Backend-only; never ship to a browser.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Optional public key (read-only dashboard / runtime fallback).
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Workspace and dataset paths (absolute paths on host)
WORKSPACE_DIR=/home/youruser/.orchestra/workspace
DATASETS_DIR=/home/youruser/.orchestra/datasets

# Ollama (for memory embeddings)
OLLAMA_URL=http://localhost:11434
OLLAMA_ORIGINS=*

# GPU device (for Docker runner)
NVIDIA_VISIBLE_DEVICES=0
