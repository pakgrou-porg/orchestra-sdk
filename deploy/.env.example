# Orchestra SDK — Environment Secrets Template
# =============================================
# Copy this file to .env in the repo root and fill in your values.
#   cp deploy/.env.example .env
#
# NEVER commit .env — it is listed in .gitignore.
# On Windows, use deploy\setup.bat to generate this file interactively.

# ── Supabase ────────────────────────────────────────────────────────────────
# Find these at: https://supabase.com/dashboard/project/<ref>/settings/api
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_ANON_KEY=eyJ...                   # "anon" / "public" key
SUPABASE_SERVICE_ROLE_KEY=eyJ...           # "service_role" key (migrations only)

# ── LLM Provider ────────────────────────────────────────────────────────────
# Set the key for whichever provider you configure in conductor_config.yaml.
# Only one key is required; the others can be left blank.

# OpenRouter (recommended — access to Claude, GPT-4, Mistral, Llama, etc.)
# Get a key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# OpenAI (direct)
# Get a key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic (direct)
# Get a key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Ollama (local embedding service for semantic memory) ────────────────────
# Default: http://localhost:11434
# Change if Ollama is running on a different host or port.
OLLAMA_URL=http://localhost:11434

# ── Optional: custom LLM endpoint ───────────────────────────────────────────
# Used when llm.provider is set to a self-hosted or custom endpoint.
# LLM_API_KEY=your-custom-key
# LLM_BASE_URL=http://localhost:8000/v1
